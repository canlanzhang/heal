


pub async fn create_article(
    pool: &PgPool,
    title: &str,
    content: &str,
    author_id: i32,
) -> Result<Article, DbError> {
    sqlx::query_as!(
        Article,
        r#"
        INSERT INTO heal_article (title, content, author_id)
        VALUES ($1, $2, $3)
        RETURNING *
        "#,
        title,
        content,
        author_id
    )
    .fetch_one(pool)
    .await
    .map_err(DbError::Sql)
}

pub async fn list_articles(pool: &PgPool) -> Result<Vec<Article>, DbError> {
    sqlx::query_as!(
        Article,
        r#"
        SELECT * FROM heal_article
        ORDER BY id DESC
        "#
    )
    .fetch_all(pool)
    .await
    .map_err(DbError::Sql)
}

pub async fn update_article(
    pool: &PgPool,
    id: i32,
    payload: &UpdateArticlePayload,
) -> Result<Article, DbError> {
    sqlx::query_as!(
        Article,
        r#"
        UPDATE heal_article
        SET
            title = COALESCE($1, title),
            content = COALESCE($2, content),
            status = COALESCE($3, status),
            updated_at = NOW()
        WHERE id = $4
        RETURNING *
        "#,
        payload.title,
        payload.content,
        payload.status,
        id
    )
    .fetch_one(pool)
    .await
    .map_err(DbError::Sql)
}

pub async fn delete_article(pool: &PgPool, id: i32) -> Result<(), DbError> {
    sqlx::query!(
        r#"DELETE FROM heal_article WHERE id = $1"#,
        id
    )
    .execute(pool)
    .await
    .map_err(DbError::Sql)?;

    Ok(())
}