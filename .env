# 1. 运行环境配置 (development / production)
APP_ENV=development
APP_PORT_HTTP=8080
APP_PORT_HTTPS=8443

# 2. 数据库连接串
DATABASE_URL=postgres://dbuser:dbpass@localhost:5432/dioxusdb

# 3. 生产级 JWT 密钥 (绝对不能硬编码在代码里)
JWT_SECRET=super_secure_random_string_that_no_one_can_guess_2026
#my_super_secret_key
# 4. 证书物理路径 (生产环境通常指向 /etc/ssl/certs/ 等系统绝对路径)
TLS_CERT_PATH=certs/cert.pem
TLS_KEY_PATH=certs/key.pem